# Fastfile for Spliiit iOS App Store deployment
# Runs on GitHub Actions macOS runner

default_platform(:ios)

platform :ios do
  desc "Build and upload to App Store Connect (TestFlight)"
  lane :beta do
    # Set up App Store Connect API key from environment
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true,
    )

    # Fetch or create signing certificates and provisioning profiles
    match(
      type: "appstore",
      app_identifier: "ca.klarityit.spliiit",
      readonly: true,
    )

    # Increment build number using timestamp (always unique)
    increment_build_number(
      build_number: Time.now.strftime("%Y%m%d%H%M"),
      xcodeproj: "ios/App/App.xcodeproj",
    )

    # Build the iOS app
    build_app(
      workspace: "ios/App/App.xcworkspace",
      scheme: "App",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "Spliiit.ipa",
      clean: true,
    )

    # Upload to TestFlight
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
    )
  end

  desc "Submit latest TestFlight build to App Store review"
  lane :release do
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true,
    )

    deliver(
      submit_for_review: true,
      automatic_release: true,
      force: true,
      skip_screenshots: true,
      skip_metadata: false,
      metadata_path: "./fastlane/metadata",
      precheck_include_in_app_purchases: false,
    )
  end
end
